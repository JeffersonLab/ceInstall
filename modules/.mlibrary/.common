# Common modulefile

conflict .mlibrary

module-whatis Utility libraries for GEMC, https://github.com/gemc/mlibrary
source [file dirname $ModulesCurrentModulefile]/../util/functions.tcl

set dir [home]/[osrelease]/mlibrary/${version}
set ilib [choose_dir $dir/lib $dir/lib64]

prepend-ldpath $ilib

setenv MLIBRARY_VERSION  $version
setenv MLIBRARY          $dir

proc ModulesTest { } {

	# Convention: 1 = PASS, 0 = FAIL
	set ok 1

	# Get MLIBRARY safely
	set mlib ""
	if { [catch { set mlib [getenv MLIBRARY] }] || $mlib eq "" } {
		if { [module-info mode load] || [module-info mode test] } {
			err "MLIBRARY is not set"
		}
		return 0
	}

	set libdir [file join $mlib lib]

	# If libdir doesn't exist, warn and fail
	if { [warndir $libdir "MLIBRARY lib directory is missing: $libdir" err] eq 0 } {
		return 0
	}

	# cadmesh lib name depends on platform
	set cadmesh_lib "libcadmesh.so"
	if { $::tcl_platform(os) eq "Darwin" } {
		set cadmesh_lib "libcadmesh.dylib"
	}

	set cadmesh_path  [file join $libdir $cadmesh_lib]
	set goptions_path [file join $libdir libgoptions.a]

	# Missing files => warn and fail
	if { [warnfile $cadmesh_path  "MLIBRARY cadmesh is not installed (missing $cadmesh_path)" err] eq 0 } {
		set ok 0
	}
	if { [warnfile $goptions_path "MLIBRARY goptions is not installed (missing $goptions_path)" err] eq 0 } {
		set ok 0
	}

	return $ok
}