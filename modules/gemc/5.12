#%Module
module-whatis GEMC for CLAS12, https://github.com/gemc/clas12Tags

set version [file tail [module-info version [module-info name]]]
set gname clas12Tags

prereq .scons_bm/1.14
prereq .cmag/1.1
prereq .mlibrary/1.9

source [file dirname $ModulesCurrentModulefile]/.common
if {[module-info mode load] && $version eq "5.12"} {
    warn "GEMC 5.12 has bad ECAL timing"
}